# =============================================================================
# .dockerignore — Keep Docker build context small
# =============================================================================

# Git
.git
.gitignore

# Build artifacts (except the musl release binary we need)
target/debug
target/release
target/.rustc_info.json
target/.cargo-lock
target/x86_64-unknown-linux-musl/debug
target/x86_64-unknown-linux-musl/release/build
target/x86_64-unknown-linux-musl/release/deps
target/x86_64-unknown-linux-musl/release/examples
target/x86_64-unknown-linux-musl/release/incremental
target/x86_64-unknown-linux-musl/release/.fingerprint
target/x86_64-unknown-linux-musl/release/*.d
target/x86_64-unknown-linux-musl/release/*.rlib

# Docs
docs/
*.md
!test/**/*.md

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
